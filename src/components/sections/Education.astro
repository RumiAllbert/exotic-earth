---
import Section from "../Section.astro";

import { certificates, education } from "@cv";

function getDomain(url?: string): string | null {
    if (!url) return null;
    try {
        return new URL(url).hostname;
    } catch {
        return null;
    }
}

function getIssuerKey(issuer: string): string {
    return issuer.toLowerCase().replace(/\s+/g, '');
}

// Map certificate issuers to their website domains for colorized favicons
const issuerDomains: Record<string, string> = {
    'amnestyinternational': 'amnesty.org',
    'crewai': 'crewai.com',
    'deeplearning.ai': 'deeplearning.ai',
    'huggingface': 'huggingface.co',
    'ibm': 'ibm.com',
    'meta': 'meta.com',
    'politecnicodimilano': 'polimi.it',
    'universityofpennsylvania': 'upenn.edu',
};

const issuerLogos: Record<string, string> = {
    'politecnicodimilano': 'https://cdn.brandfetch.io/idUnYfGpnn/w/400/h/400/theme/dark/icon.jpeg?c=1bxid64Mup7aczewSAYMX&t=1774827839118',
};

function getIssuerDomain(issuer: string): string | null {
    const key = getIssuerKey(issuer);
    return issuerDomains[key] || null;
}

function getIssuerLogo(issuer: string): string | null {
    const key = getIssuerKey(issuer);
    return issuerLogos[key] || null;
}

---

<Section className={Astro.props.className} title="Education">
	<ul class="space-y-4 py-3 print:space-y-0">
		{
			education.map(({ institution, startDate, endDate, area, url, studyType, highlights }) => {
				const startYear = new Date(startDate).getFullYear();
				const endYear = endDate != null ? new Date(endDate).getFullYear() : "Actual";
				const years = `${startYear} - ${endYear}`;
				const domain = getDomain(url);

				return (
					<div class="flex items-start">
						{domain ? (
							<img
								src={`https://www.google.com/s2/favicons?domain=${domain}&sz=64`}
								alt={institution}
								width="28"
								height="28"
								class="mr-3 mt-2 h-7 w-7 shrink-0 rounded-sm print:hidden"
								loading="lazy"
							/>
						) : (
							<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-3 mt-2 h-7 w-7 shrink-0 print:hidden text-skin-muted">
								<path d="M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z" />
								<path d="M22 10v6" />
								<path d="M6 12.5V16a6 3 0 0 0 12 0v-3.5" />
							</svg>
						)}
						<div class="relative w-full items-baseline justify-between gap-2">
							<h3 class="mr-6 items-baseline gap-x-2 gap-y-0.5 font-medium">
								<a target="_blank" class="hover:text-skin-hue group flex items-center gap-[6px] decoration-dotted underline-offset-[5px] hover:underline" href={url}>
									{institution}
								</a>
							</h3>
							<div class="text-sm text-skin-muted">{studyType} in {area}</div>
							<time class="right-0 top-0 text-xs text-skin-muted md:absolute md:block">{years}</time>
							{highlights && highlights.length > 0 && (
								<ul class="mt-2 list-disc pl-5 text-sm text-skin-muted">
									{highlights.map((highlight) => (
										<li>{highlight}</li>
									))}
								</ul>
							)}
						</div>
					</div>
				);
			})
		}
	</ul>

	{
		certificates.length > 0 && (
			<>
				<h4 class="text-lg font-semibold mb-2">Certificates</h4>
				<ul class="grid gap-2.5 py-3 sm:grid-cols-2 print:block print:space-y-2">
					{certificates.map(({ name, date, issuer, url }) => {
						const certificateYear = new Date(date).getFullYear();
						const certLogoSrc = getIssuerLogo(issuer);
						const certDomain = getIssuerDomain(issuer) || getDomain(url);
						const certIconSrc = certLogoSrc ?? (certDomain ? `https://www.google.com/s2/favicons?domain=${certDomain}&sz=64` : null);
						return (
							<li class="h-full print:mb-2">
								<a
									class="group flex h-full items-center gap-2.5 rounded-lg bg-skin-fill p-2.5 ring-1 ring-skin-muted/20 transition-all duration-200 hover:-translate-y-0.5 hover:ring-skin-hue/25 print:transform-none print:rounded-none print:p-0 print:ring-0"
									href={url}
									target="_blank"
									rel="noopener noreferrer"
								>
									{certIconSrc ? (
										<img
											src={certIconSrc}
											alt={issuer}
											width="32"
											height="32"
											class="h-8 w-8 shrink-0 rounded-md object-cover print:hidden"
											loading="lazy"
										/>
									) : (
										<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-8 w-8 shrink-0 text-skin-muted print:hidden">
											<path d="M15 12h-5" />
											<path d="M15 8h-5" />
											<path d="M19 17V5a2 2 0 0 0-2-2H4" />
											<path d="M8 21h12a2 2 0 0 0 2-2v-1a1 1 0 0 0-1-1H11a1 1 0 0 0-1 1v1a2 2 0 1 1-4 0V5a2 2 0 1 0-4 0v2a1 1 0 0 0 1 1h3" />
										</svg>
									)}
									<div class="min-w-0 flex-1">
										<div class="flex items-start justify-between gap-2">
											<h3 class="text-sm font-medium leading-snug text-skin-base transition-colors group-hover:text-skin-hue print:text-skin-base">
												{name}
											</h3>
											<time class="shrink-0 rounded-full bg-skin-button-muted/60 px-1.5 py-0.5 text-[10px] font-medium text-skin-muted ring-1 ring-skin-muted/10 print:bg-transparent print:p-0 print:ring-0">
												{certificateYear}
											</time>
										</div>
										<div class="mt-0.5 text-xs leading-tight text-skin-muted">{issuer}</div>
									</div>
								</a>
							</li>
						);
					})}
				</ul>
			</>
		)
	}
</Section>
